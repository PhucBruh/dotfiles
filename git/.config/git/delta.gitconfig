[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictStyle = zdiff3

[delta]
  syntax-theme = tokyonight_storm
  side-by-side = true
  navigate = true

  plus-style = syntax "#1f3b2b"
  minus-style = syntax "#3b1f2b"

  file-style = "#7aa2f7" bold
  hunk-header-style = "#bb9af7"
