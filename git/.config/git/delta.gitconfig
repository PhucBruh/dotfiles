[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictStyle = zdiff3

[delta]
  features = cyberdream

  plus-style  = syntax "#1e2a22"
  minus-style = syntax "#2a1e1e"

  plus-emph-style  = syntax bold "#2a3e2e"
  minus-emph-style = syntax bold "#3e2a2a"

[delta "decorations"]
  syntax-theme = cyberdream
